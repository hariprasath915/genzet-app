# GenZet Backend — Environment Variables
# ========================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Anthropic Claude API ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── JWT Authentication ────────────────────────────────────────────────
# Generate a strong secret key with:
#   python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=your_generated_jwt_secret_key_here

# Token expiry in days (default: 900)
JWT_EXPIRE_DAYS=900

# ── Database ───────────────────────────────────────────────────────────
# SQLite (default):
# DATABASE_URL=sqlite:///./genzet.db

# PostgreSQL (for production):
DATABASE_URL=postgresql://username:password@host:5432/dbname

# ── Backend server ─────────────────────────────────────────────────────
# During development:
BACKEND_URL=http://localhost:8000

# In production (update after Render deployment):
# BACKEND_URL=https://animind-backend.onrender.com